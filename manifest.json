{
  "manifest_version": 3,
  "name": "Gradescope Submission Stopwatch",
  "description": "Displays a stopwatch on Gradescope submission grading pages to track grading time per submission.",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "gradescope-stopwatch-7f3a9c2e@temporary.local",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.gradescope.com/courses/*/questions/*/submissions/*/grade*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ]
}
